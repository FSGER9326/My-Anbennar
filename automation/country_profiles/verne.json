{
  "name": "verne",
  "require_patterns": [
    {
      "description": "helper layer: preserves Port-of-Adventure unlock flag",
      "pattern": "set_country_flag = verne_unlock_port_of_adventure_button",
      "paths": [
        "common/scripted_effects/verne_overhaul_effects.txt"
      ]
    },
    {
      "description": "helper layer: monument anchor IDs exist",
      "pattern": "^kazakesh\\s*=|^aur_kes_akasik\\s*=|^kazakesh_stingport\\s*=",
      "paths": [
        "common/great_projects/anb_monuments_sarhal.txt",
        "common/great_projects/anb_monuments_missions.txt"
      ]
    },
    {
      "description": "foundation layer: Verne overhaul modifier objects exist",
      "pattern": "^verne_[a-z0-9_]+\\s*=\\s*\\{",
      "paths": [
        "common/event_modifiers/verne_overhaul_modifiers.txt"
      ]
    },
    {
      "description": "foundation layer: Verne overhaul localisation file keeps l_english header",
      "pattern": "^l_english\\s*:\\s*$",
      "paths": [
        "localisation/verne_overhaul_l_english.yml"
      ]
    },
    {
      "description": "foundation layer: Verne overhaul localisation keys are present",
      "pattern": "^\\s*(?:desc_)?verne_[a-z0-9_]+\\s*:\\s*0\\b",
      "paths": [
        "localisation/verne_overhaul_l_english.yml"
      ]
    },
    {
      "description": "foundation layer: Verne doctrine group objects exist",
      "pattern": "^verne_[a-z0-9_]+\\s*=\\s*\\{",
      "paths": [
        "common/ideas/verne_doctrine_groups.txt"
      ]
    },
    {
      "description": "foundation layer: Verne overhaul reform objects exist",
      "pattern": "^verne_[a-z0-9_]+\\s*=\\s*\\{",
      "paths": [
        "common/government_reforms/verne_overhaul_reforms.txt"
      ]
    },
    {
      "description": "foundation layer: Verne dynasty event objects exist",
      "pattern": "^(?:country_event|province_event)\\s*=\\s*\\{",
      "paths": [
        "events/verne_overhaul_dynasty_events.txt"
      ]
    },
    {
      "description": "foundation layer: Verne on_actions hooks exist",
      "pattern": "^[a-z0-9_]+\\s*=\\s*\\{",
      "paths": [
        "common/on_actions/zz_verne_overhaul_on_actions.txt"
      ]
    }
  ],
  "require_all_patterns": [
    {
      "description": "helper layer: helper definitions exist (ALL patterns must match somewhere in paths)",
      "patterns": [
        "verne_overhaul_enable_adventure_network_tier_1",
        "verne_overhaul_apply_regatta_spire_swap",
        "verne_overhaul_laments_regatta_anchor_state_ready",
        "verne_overhaul_akasik_access_ready"
      ],
      "paths": [
        "common/scripted_effects/verne_overhaul_effects.txt",
        "common/scripted_triggers/verne_overhaul_triggers.txt"
      ]
    },
    {
      "description": "helper layer: mission/event call sites use helpers (ALL patterns must match somewhere in paths)",
      "patterns": [
        "verne_overhaul_enable_adventure_network_tier_1",
        "verne_overhaul_apply_regatta_spire_swap",
        "verne_overhaul_laments_regatta_anchor_state_ready",
        "verne_overhaul_akasik_access_ready"
      ],
      "paths": [
        "missions/Verne_Missions.txt",
        "events/Flavour_Verne_A33.txt"
      ]
    },
    {
      "description": "foundation layer: doctrine+reform sentinel IDs must exist (ALL patterns must match somewhere in paths)",
      "patterns": [
        "verne_doctrine_way_of_the_wave",
        "verne_overhaul_admiralty_council_reform"
      ],
      "paths": [
        "common/ideas/verne_doctrine_groups.txt",
        "common/government_reforms/verne_overhaul_reforms.txt"
      ]
    }
  ],
  "forbid_patterns": [
    {
      "description": "helper layer: no stale inline duplicate logic in mission/event call sites",
      "pattern": "destroy_great_project|add_great_project|set_country_flag = verne_unlock_port_of_adventure_button|name = \"verne_network_of_adventure_tier_1\"",
      "paths": [
        "missions/Verne_Missions.txt",
        "events/Flavour_Verne_A33.txt"
      ]
    },
    {
      "description": "foundation layer: no unresolved merge markers in new Verne foundation files",
      "pattern": "^<<<<<<<|^=======|^>>>>>>>",
      "paths": [
        "common/event_modifiers/verne_overhaul_modifiers.txt",
        "localisation/verne_overhaul_l_english.yml"
      ]
    },
    {
      "description": "foundation layer: no placeholder TODO keys in localisation foundation file",
      "pattern": "^\\s*(?:desc_)?(?:TODO|todo|placeholder|replace_me|verne_todo|verne_overhaul_todo)[a-z0-9_]*\\s*:",
      "paths": [
        "localisation/verne_overhaul_l_english.yml"
      ]
    },
    {
      "description": "foundation layer: no TODO placeholders left in modifier foundation file",
      "pattern": "#\\s*TODO\\b|\\bTODO\\b",
      "paths": [
        "common/event_modifiers/verne_overhaul_modifiers.txt"
      ]
    },
    {
      "description": "foundation layer: no inconsistent Verne overhaul prefix typos",
      "pattern": "verne_overhual_|vern_overhaul_|verne-overhaul_|verneOverhaul_|verneoverhaul_",
      "paths": [
        "common/event_modifiers/verne_overhaul_modifiers.txt",
        "localisation/verne_overhaul_l_english.yml"
      ]
    },
    {
      "description": "foundation layer: no placeholder doctrine/reform keys in new Verne doctrine and reform files",
      "pattern": "^\\s*(?:TODO|todo|placeholder|replace_me|verne_todo|verne_overhaul_todo)[a-z0-9_]*\\s*=",
      "paths": [
        "common/ideas/verne_doctrine_groups.txt",
        "common/government_reforms/verne_overhaul_reforms.txt"
      ]
    },
    {
      "description": "foundation layer: no unresolved merge markers in Verne doctrine/reform/event/on_actions files",
      "pattern": "^<<<<<<<|^=======|^>>>>>>>",
      "paths": [
        "common/ideas/verne_doctrine_groups.txt",
        "common/government_reforms/verne_overhaul_reforms.txt",
        "events/verne_overhaul_dynasty_events.txt",
        "common/on_actions/zz_verne_overhaul_on_actions.txt"
      ]
    },
    {
      "description": "foundation layer: no placeholder TODO keys in Verne doctrine/reform/event/on_actions files",
      "pattern": "^\\s*(?:TODO|todo|placeholder|replace_me|verne_todo|verne_overhaul_todo)[a-z0-9_]*\\s*(?:=|:)",
      "paths": [
        "common/ideas/verne_doctrine_groups.txt",
        "common/government_reforms/verne_overhaul_reforms.txt",
        "events/verne_overhaul_dynasty_events.txt",
        "common/on_actions/zz_verne_overhaul_on_actions.txt"
      ]
    }
  ],
  "structural_checks": [
    "common/scripted_effects/verne_overhaul_effects.txt",
    "common/scripted_triggers/verne_overhaul_triggers.txt"
  ]
}
