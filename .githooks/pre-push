#!/bin/sh
set -eu

echo "[hook] pre-push: running smart smoke router before push"

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/smart_smoke_router.ps1 -Mode pre-push
fi

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File scripts/smart_smoke_router.ps1 -Mode pre-push
fi

if command -v bash >/dev/null 2>&1; then
  exec bash scripts/smart_smoke_router.sh --mode pre-push
fi

echo "ERROR: no supported shell found for pre-push hook." >&2
exit 1
